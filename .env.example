# Supabase browser client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side automation runner. Never expose this key as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron sends Authorization: Bearer $CRON_SECRET.
CRON_SECRET=

# Legacy/local compatibility. Prefer NEXT_PUBLIC_* in Next.js.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth redirects
NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=https://tipsedu.co.kr
NEXT_PUBLIC_SITE_URL=https://tipsedu.co.kr

# Optional role fallbacks
NEXT_PUBLIC_FALLBACK_ADMIN_EMAILS=
NEXT_PUBLIC_FALLBACK_STAFF_EMAILS=
NEXT_PUBLIC_FALLBACK_TEACHER_EMAILS=

# Google Chat incoming webhook URLs, resolved server-side from channel secret refs.
GOOGLE_CHAT_WEBHOOK_TEACHERS=
GOOGLE_CHAT_WEBHOOK_ASSISTANTS=
GOOGLE_CHAT_WEBHOOK_ENGLISH=
GOOGLE_CHAT_WEBHOOK_MATH=
GOOGLE_CHAT_WEBHOOK_DESK=
GOOGLE_CHAT_WEBHOOK_ADMIN=
GOOGLE_CHAT_WEBHOOK_PRINCIPAL=
GOOGLE_CHAT_WEBHOOK_ALL=
